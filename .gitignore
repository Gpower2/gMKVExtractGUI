.gitignore - generated by script
# ========== OS generated ===========
# Windows thumbnail and system files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
$RECYCLE.BIN/

# ========== Visual Studio ===========
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db

# ========== IDEs & editors ===========
.vscode/
.idea/
*.sln.iml
*.DotSettings.user

# ========== Build outputs ===========
[Bb]in/
[Oo]bj/
build/
publish/

# ========== NuGet / Packages ===========
# Ignore packages directory and NuGet packages produced during build
packages/
*.nupkg
project.lock.json
project.fragment.lock.json

# ========== Test results & coverage ===========
TestResults/
coverage/
*.coverage
*.coveragexml

# ========== Logs & temporary files ===========
~$*
*.tmp
*.temp
*.log
*.cache
*.bak
*.swp
*.orig
*.rej

# ========== Misc / OS specific ===========
*.pid
*.pid.lock

# End of file
